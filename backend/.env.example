# ==============================================================================
# ALT-TRAVEL SAAS SERVER CONFIGURATION
# ==============================================================================

# Core Application Settings
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=production
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://yourfrontenddomain.com

# Admin Authentication Token
# Access key used to unlock the B2B Tourism Board Analytics Dashboard
ADMIN_DASHBOARD_PASSWORD=alt-travel-admin-pass-2026

# Database & Cache Configurations
# PostGIS enabled PostgreSQL string (e.g., Supabase, Neon, or Local instance)
DATABASE_URL=postgresql://postgres_user:your_secure_db_password@localhost:5432/alttravel_db
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# ADVANCED THIRD-PARTY API CREDENTIALS (BACKEND PROXY KEYS)
# ==============================================================================

# 1. Google Gemini AI Engine
# Powers structured JSON outputs, aesthetic token analysis, and text embeddings
GOOGLE_API_KEY=AIzaSyYourActualGoogleAIStudioOrCloudKeyHere

# 2. Mapbox GL JS & Spatial Matrix Routing
# Secret key handles server-side geocoding and distance matrix matrix calculations
MAPBOX_SECRET_TOKEN=sk.eyJ1IjoieYourSecretMapboxServerKeyHere

# 3. Amadeus Travel Intelligence Network
# Ingests multi-modal flight data, points-of-interest, and carbon footprint calculations
AMADEUS_CLIENT_ID=your_amadeus_client_id_alphanumeric_string
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_alphanumeric_string

# 4. Radar.io Geofencing Platform
# Runs secure, backend geometric verification for "Eco-Pass" mobile check-ins
RADAR_SECRET_KEY=prj_live_sk_your_radar_production_secret_key_here

# 5. Web Scraping & Crowd Ingestion Browser Proxy (Optional)
# Prevents IP bans when scraping real-time aggregate search engine traffic graphs
BRIGHTDATA_PROXY_URL=http://brd-customer-hl_your_id:your_password@brd.superproxy.io:22225
